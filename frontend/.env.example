 ===========================================
# Frontend Vite
# ===========================================
# Base URL de l’API appelée par le front (ajustez selon votre env)
VITE_API_BASE_URL=http://localhost:8000

# OAuth Google (flux authorization code) — client_id public ; redirect_uri = URL exacte enregistrée dans Google Cloud
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Clé site reCAPTCHA v2 (publique) — même paire que RECAPTCHA_SECRET_KEY côté backend
VITE_RECAPTCHA_SITE_KEY=<recaptcha_site_key>

VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_TRACES_SAMPLE_RATE=1.0


