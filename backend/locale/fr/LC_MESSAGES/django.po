#: templates/account/email/base_message.html:29
#, python-format
msgid "© %(site_name)s. All rights reserved."
msgstr "© %(site_name)s. Tous droits réservés."

#: templates/account/email/email_confirmation_message.html:4
msgid "Confirm your email address"
msgstr "Confirmez votre adresse e-mail"

#: templates/account/email/email_confirmation_message.html:8
msgid "Account Verification"
msgstr "Vérification du compte"

#: templates/account/email/email_confirmation_message.html:12
#: templates/account/email/welcome_message.html:12
#, python-format
msgid "Hi %(user_display)s,"
msgstr "Bonjour %(user_display)s,"

#: templates/account/email/email_confirmation_message.html:15
#, python-format
msgid ""
"Welcome to LudoKan! To finalize your registration on %(site_domain)s, please "
"confirm your email address by clicking the button below:"
msgstr ""
"Bienvenue sur LudoKan ! Pour finaliser votre inscription sur %(site_domain)s, "
"veuillez confirmer votre adresse e-mail en cliquant sur le bouton ci-dessous :"

#: templates/account/email/email_confirmation_message.html:18
msgid "Confirm my email"
msgstr "Confirmer mon adresse e-mail"

#: templates/account/email/email_confirmation_message.html:22
#: templates/account/email/password_reset_key_message.html:28
msgid "If the button doesn't work, copy and paste this link into your browser:"
msgstr ""
"Si le bouton ne fonctionne pas, copiez-collez ce lien dans votre navigateur :"

#: templates/account/email/email_confirmation_message.html:30
msgid ""
"If you did not create an account on LudoKan, you can safely ignore this "
"email."
msgstr ""
"Si vous n’avez pas créé de compte sur LudoKan, vous pouvez ignorer cet e-mail."

#: templates/account/email/email_confirmation_message.txt:1
#, python-format
msgid ""
"Hi %(user_display)s,\n"
"\n"
"Welcome to LudoKan!\n"
"\n"
"To finalize your registration on %(site_domain)s, please confirm your email "
"address by clicking the following link:\n"
"\n"
"%(activate_url)s\n"
"\n"
"If you did not create an account on LudoKan, you can safely ignore this "
"email.\n"
"\n"
"Thank you,\n"
"The LudoKan team"
msgstr ""
"Bonjour %(user_display)s,\n"
"\n"
"Bienvenue sur LudoKan !\n"
"\n"
"Pour finaliser votre inscription sur %(site_domain)s, veuillez confirmer votre "
"adresse e-mail en cliquant sur le lien suivant :\n"
"\n"
"%(activate_url)s\n"
"\n"
"Si vous n’avez pas créé de compte sur LudoKan, vous pouvez ignorer cet e-mail.\n"
"\n"
"Merci,\n"
"L’équipe LudoKan"

#: templates/account/email/email_confirmation_subject.txt:3
msgid "Please Confirm Your Email Address"
msgstr "Veuillez confirmer votre adresse e-mail"

#: templates/account/email/password_reset_key_message.html:4
msgid "Reset your password"
msgstr "Réinitialisez votre mot de passe"

#: templates/account/email/password_reset_key_message.html:8
msgid "Password Reset"
msgstr "Réinitialisation du mot de passe"

#: templates/account/email/password_reset_key_message.html:11
msgid "Hi,"
msgstr "Bonjour,"

#: templates/account/email/password_reset_key_message.html:14
msgid ""
"You have requested to reset your password on LudoKan. Click the button below "
"to choose a new password:"
msgstr ""
"Vous avez demandé la réinitialisation de votre mot de passe sur LudoKan. "
"Cliquez sur le bouton ci-dessous pour en choisir un nouveau :"

#: templates/account/email/password_reset_key_message.html:17
msgid "Reset my password"
msgstr "Réinitialiser mon mot de passe"

#: templates/account/email/password_reset_key_message.html:23
msgid "This link expires in 10 minutes."
msgstr "Ce lien expire dans 10 minutes."

#: templates/account/email/password_reset_key_message.html:36
msgid ""
"If you did not request this reset, you can safely ignore this email. Your "
"password will remain unchanged."
msgstr ""
"Si vous n’avez pas demandé cette réinitialisation, vous pouvez ignorer cet "
"e-mail. Votre mot de passe restera inchangé."

#: templates/account/email/password_reset_key_message.txt:1
#, python-format
msgid ""
"Hello,\n"
"\n"
"You have requested to reset your password on LudoKan.\n"
"\n"
"Please click the following link to choose a new password:\n"
"\n"
"%(password_reset_url)s\n"
"\n"
"⚠ This link expires in 10 minutes.\n"
"\n"
"If you did not request this reset, you can safely ignore this email.\n"
"Your password will remain unchanged.\n"
"\n"
"Thank you,\n"
"The LudoKan team"
msgstr ""
"Bonjour,\n"
"\n"
"Vous avez demandé la réinitialisation de votre mot de passe sur LudoKan.\n"
"\n"
"Veuillez cliquer sur le lien suivant pour en choisir un nouveau :\n"
"\n"
"%(password_reset_url)s\n"
"\n"
"⚠ Ce lien expire dans 10 minutes.\n"
"\n"
"Si vous n’avez pas demandé cette réinitialisation, vous pouvez ignorer cet "
"e-mail.\n"
"Votre mot de passe restera inchangé.\n"
"\n"
"Merci,\n"
"L’équipe LudoKan"

#: templates/account/email/password_reset_key_subject.txt:1
#, python-format
msgid "%(site_name)s – Reset your password"
msgstr "%(site_name)s – Réinitialisation de votre mot de passe"

#: templates/account/email/welcome_message.html:4
#: templates/account/email/welcome_subject.txt:1
msgid "Welcome to LudoKan!"
msgstr "Bienvenue sur LudoKan !"

#: templates/account/email/welcome_message.html:8
msgid "Welcome"
msgstr "Bienvenue"

#: templates/account/email/welcome_message.html:15
msgid ""
"Your account has been successfully verified! We are thrilled to have you in "
"the LudoKan community."
msgstr ""
"Votre compte a bien été vérifié ! Nous sommes ravis de vous accueillir dans la "
"communauté LudoKan."

#: templates/account/email/welcome_message.html:18
msgid ""
"You can now start exploring games, tracking your library, and connecting "
"with other players."
msgstr ""
"Vous pouvez désormais explorer les jeux, suivre votre bibliothèque et "
"échanger avec d’autres joueurs."

#: templates/account/email/welcome_message.html:21
msgid "Go to LudoKan"
msgstr "Accéder à LudoKan"

#: templates/account/email/welcome_message.html:25
msgid "See you soon on LudoKan!"
msgstr "À très vite sur LudoKan !"

#: templates/account/email/welcome_message.txt:1
#, python-format
msgid ""
"Hi %(user_display)s,\n"
"\n"
"Welcome to LudoKan!\n"
"\n"
"Your account has been successfully verified! We are thrilled to have you in "
"the LudoKan community.\n"
"\n"
"You can now start exploring games, tracking your library, and connecting "
"with other players.\n"
"\n"
"Go to LudoKan: %(frontend_url)s\n"
"\n"
"See you soon,\n"
"The LudoKan team"
msgstr ""
"Bonjour %(user_display)s,\n"
"\n"
"Bienvenue sur LudoKan !\n"
"\n"
"Votre compte a bien été vérifié ! Nous sommes ravis de vous accueillir dans la "
"communauté LudoKan.\n"
"\n"
"Vous pouvez désormais explorer les jeux, suivre votre bibliothèque et "
"échanger avec d’autres joueurs.\n"
"\n"
"Accéder à LudoKan : %(frontend_url)s\n"
"\n"
"À très vite,\n"
"L’équipe LudoKan"
