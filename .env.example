# ===========================================
# CONFIGURATION LUDOKAN - FICHIER EXEMPLE
# ===========================================

# ===========================================
# BASE DE DONNÉES
# ===========================================
POSTGRES_DB=<postgres_db_name>
POSTGRES_USER=<postgres_user>
POSTGRES_PASSWORD=<postgres_password>
# Service/host du conteneur ou de l’instance (ex: db, localhost, 127.0.0.1)
POSTGRES_HOST=<postgres_host>
POSTGRES_PORT=5432

# URL complète si votre stack l’utilise (prioritaire sur les variables ci-dessus)
# Exemple: postgresql://USER:PASS@HOST:PORT/DBNAME
DATABASE_URL=postgresql://<postgres_user>:<postgres_password>@<postgres_host>:<postgres_port>/<postgres_db_name>

# ===========================================
# DJANGO
# ===========================================
# Générez une vraie clé pour la prod (ex: `python -c "import secrets; print(secrets.token_urlsafe(50))"`)
SECRET_KEY=<django_secret_key>
# False en prod, True uniquement en dev
DEBUG=False
# Séparez par des virgules sans espaces
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# Clé secrète reCAPTCHA v2 (console Google) — obligatoire pour que le login API accepte les requêtes
RECAPTCHA_SECRET_KEY=<recaptcha_secret_key>
# true seulement derrière un reverse-proxy qui renvoie la vraie IP (X-Forwarded-For). Laisser false en Docker local.
RECAPTCHA_SEND_REMOTEIP=false

# ---------------------------------------------------------------------------
# Multi-environnement (quotas email / Redis, contexte logs — voir backend/config/settings.py)
# ---------------------------------------------------------------------------
# Valeurs typiques : local | staging | production
# - local      : dev — console ou Mailpit, quotas souvent désactivés
# - staging    : préprod — SMTP réel (ex. Resend), sujets préfixés, allowlist possible
# - production : trafic réel — quotas recommandés, domaine et expéditeurs vérifiés chez le fournisseur SMTP
ENVIRONMENT=local

# ===========================================
# SITE (django.contrib.sites / allauth — liens dans les e-mails)
# ===========================================
# Après modification : docker compose exec web python manage.py sync_site
SITE_ID=1
SITE_DOMAIN=ludokan-local.fr
SITE_NAME=LudoKan Local

# ===========================================
# EMAIL (allauth / reset / Celery / rapports)
# ===========================================
# Expéditeur par défaut des e-mails transactionnels (doit être autorisé chez votre fournisseur SMTP en prod).
DEFAULT_FROM_EMAIL=<noreply@example.com>
# Expéditeur des messages système Django (erreurs 500, etc.). Souvent identique à DEFAULT_FROM_EMAIL.
SERVER_EMAIL=<noreply@example.com>

# Préfixe des sujets pour le mail Django « générique » (admins, etc.) — garder un espace final pour séparer le titre.
EMAIL_SUBJECT_PREFIX="[LudoKan] "
# Préfixe des sujets django-allauth (confirmation d’e-mail, etc.). Exemples par environnement :
#   local / docker dev  → "[LOCAL] "   ou   "[LudoKan Local] "
#   staging / préprod   → "[LudoKan Staging] "
#   production          → "[LudoKan] "
# Si absent : même valeur que EMAIL_SUBJECT_PREFIX (voir backend/config/settings.py).
ACCOUNT_EMAIL_SUBJECT_PREFIX="[LudoKan] "
# mandatory | optional | none — en local, optional accélère les tests sans boîte mail réelle.
ACCOUNT_EMAIL_VERIFICATION=mandatory

# ---------------------------------------------------------------------------
# Choix du backend
# ---------------------------------------------------------------------------
# local sans SMTP : logs uniquement
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# local avec Mailpit (service docker-compose « mailpit », ports 1025 SMTP / 8025 UI web) :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=mailpit
# EMAIL_PORT=1025
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=False
# EMAIL_USE_SSL=False
# EMAIL_TIMEOUT=10
# Hors Docker : EMAIL_HOST=127.0.0.1 si Mailpit tourne sur la machine hôte.

# ---------------------------------------------------------------------------
# SMTP générique (fournisseur autre que Resend, ou valeurs par défaut avant surcharge)
# ---------------------------------------------------------------------------
EMAIL_HOST=<smtp_host>
EMAIL_PORT=587
EMAIL_HOST_USER=<smtp_user>
EMAIL_HOST_PASSWORD=<smtp_password>
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
# Délai max (secondes) pour la connexion / l’envoi SMTP
EMAIL_TIMEOUT=10

# ---------------------------------------------------------------------------
# Resend (staging / production) — envoi via SMTP Resend
# ---------------------------------------------------------------------------
# Doc : https://resend.com/docs/send-with-django-smtp
# - Créer une clé API sur le dashboard Resend ; vérifier le domaine d’envoi et utiliser la même adresse en DEFAULT_FROM_EMAIL.
# - USERNAME SMTP fixe : resend  |  PASSWORD : votre clé API Resend
# Exemple (à décommenter et adapter) :
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.resend.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=resend
# EMAIL_HOST_PASSWORD=<resend_api_key>
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_TIMEOUT=30

# ---------------------------------------------------------------------------
# Quotas d’envoi (anti-abus — comptage via cache Redis, voir apps.core.email_quota)
# ---------------------------------------------------------------------------
# local : False pour ne pas bloquer les tests
# staging / production : True recommandé ; ajuster les plafonds selon votre offre SMTP
EMAIL_QUOTA_ENABLED=False
EMAIL_DAILY_LIMIT=80
EMAIL_MONTHLY_LIMIT=2500

# ---------------------------------------------------------------------------
# Allowlist optionnelle (staging / debug) — si activée, seules ces adresses reçoivent des mails
# ---------------------------------------------------------------------------
# Liste séparée par des virgules, sans espaces autour des e-mails.
EMAIL_ALLOWLIST_ENABLED=False
EMAIL_ALLOWLIST=

# ===========================================
# REDIS
# ===========================================
# Hôte du service Redis (ex: redis, localhost)
REDIS_HOST=<redis_host>
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://<redis_host>:<redis_port>/<redis_db>

# ===========================================
# CELERY
# ===========================================
CELERY_BROKER_URL=redis://<redis_host>:<redis_port>/0
CELERY_RESULT_BACKEND=redis://<redis_host>:<redis_port>/1

# ===========================================
# CORS (Cross-Origin Resource Sharing)
# ===========================================
# Origines autorisées (séparées par des virgules). Mettez vos URLs front ici.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=True

# ===========================================
# STATIC & MEDIA
# ===========================================
STATIC_URL=/static/
STATIC_ROOT=/app/static
MEDIA_URL=/media/
MEDIA_ROOT=/app/media

# ===========================================
# Frontend Vite
# ===========================================
# Base URL de l’API appelée par le front (ajustez selon votre env)
VITE_API_BASE_URL=http://localhost:8000



JWT_ACCESS_TOKEN_LIFETIME=15
JWT_REFRESH_TOKEN_LIFETIME=10080
FRONTEND_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:5173
